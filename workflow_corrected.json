            "id": "fbc8640f-fc3d-4576-93d4-3f5bc0f7439d",
            "name": "Google Custom Search",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                -1328,
                208
            ]
        },
        {
            "parameters": {
                "jsCode": "const items = $input.all();\nconst results = [];\nconst skipDomains = ['pinterest', 'facebook.com', 'twitter.com', 'instagram.com', 'tiktok.com', 'reddit.com'];\n\nfor (const item of items) {\n  const searchResults = item.json.items || [];\n  const queryQ = item.json.queries?.request?.[0]?.searchTerms || '';\n  \n  let sourceType = 'academic';\n  if (queryQ.includes('vocabulario') || queryQ.includes('vocabulary') || queryQ.includes('frases') || queryQ.includes('learning')) sourceType = 'vocabulary';\n  if (queryQ.includes('noticias') || queryQ.includes('news')) sourceType = 'news';\n\n  for (const r of searchResults) {\n    const url = r.link || '';\n    if (skipDomains.some(d => url.includes(d))) continue;\n    results.push({\n      json: {\n        title: r.title || '',\n        url,\n        snippet: r.snippet || '',\n        source_type: sourceType,\n        display_link: r.displayLink || ''\n      }\n    });\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { _empty: true } }];"
            },
            "id": "b4367707-b5fd-4ec1-9850-9bac54b01fc6",
            "name": "Extraer Resultados",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
