                            "name": "queries",
                            "value": "={{ [\n  { \"q\": \"kichwa language linguistics research site:academia.edu OR site:jstor.org OR site:scielo.org\", \"type\": \"academic\", \"lang\": \"kichwa\" },\n  { \"q\": \"shuar language linguistics Ecuador research paper\", \"type\": \"academic\", \"lang\": \"shuar\" },\n  { \"q\": \"lengua kichwa vocabulario frases recursos libres\", \"type\": \"vocabulary\", \"lang\": \"kichwa\" },\n  { \"q\": \"kichwa quechua open educational resources OER free\", \"type\": \"vocabulary\", \"lang\": \"kichwa\" },\n  { \"q\": \"pueblos amazónicos Ecuador noticias 2025\", \"type\": \"news\", \"lang\": \"general\" },\n  { \"q\": \"indigenous amazonian languages preservation Ecuador 2025\", \"type\": \"academic\", \"lang\": \"general\" },\n  { \"q\": \"shuar achuar language learning free resources\", \"type\": \"vocabulary\", \"lang\": \"shuar\" },\n  { \"q\": \"kichwa grammar dictionary PDF free download\", \"type\": \"academic\", \"lang\": \"kichwa\" }\n] }}",
