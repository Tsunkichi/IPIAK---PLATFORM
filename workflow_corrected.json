        {
            "parameters": {
                "method": "POST",
                "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
                "sendQuery": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "key",
                            "value": "AIzaSyCbSgY1AcwyAAL4oQD0smWopmlWG-j4_Zc"
                        }
                    ]
                },
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({ contents: [{ parts: [{ text: 'Analiza este recurso web para determinar su relevancia para el aprendizaje de lenguas indígenas amazónicas (kichwa, shuar, achuar, etc.):\\n\\nTítulo: ' + $json.title + '\\nURL: ' + $json.url + '\\nFragmento: ' + $json.snippet + '\\nTipo de fuente: ' + $json.source_type + '\\n\\nResponde SOLO en formato JSON (sin markdown, sin ```json) con esta estructura exacta:\\n{\"relevant\": true/false, \"relevance_score\": 1-10, \"content_type\": \"academic\"|\"vocabulary\"|\"news\"|\"multimedia\"|\"other\", \"language\": \"kichwa\"|\"shuar\"|\"general\"|\"otro\", \"summary\": \"resumen breve en español\", \"tags\": [\"etiqueta1\", \"etiqueta2\"]}' }] }] }) }}",
                "options": {
                    "timeout": 15000
                }
            },
            "id": "288b6b73-54d7-4972-af40-db6440e3b79d",
            "name": "Gemini – Analizar",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                -656,
                112
            ]
        },
        {
            "parameters": {
                "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  try {\n    const raw = item.json.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\n    const clean = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n    const analysis = JSON.parse(clean);\n\n    if (analysis.relevant === true && (analysis.relevance_score || 0) >= 7) {\n      results.push({\n        json: {\n          title: item.json.title || '',\n          url: item.json.url || '',\n          source_type: analysis.content_type || item.json.source_type || 'other',\n          language: analysis.language || 'general',\n          summary: analysis.summary || '',\n          relevance_score: analysis.relevance_score || 7,\n          tags: analysis.tags || [],\n          display_link: item.json.display_link || ''\n        }\n      });\n    }\n  } catch (e) {\n    // JSON malformado de Gemini, ignorar\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { _skip: true } }];"
            },
