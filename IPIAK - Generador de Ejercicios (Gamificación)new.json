    {
      "parameters": {
        "jsCode": "const driveFiles = $('List Drive Files').all();\nconst processedDocs = $input.all();\n\nconsole.log(`Docs from Drive: ${driveFiles.length}`);\nconsole.log(`Docs in Supabase: ${processedDocs.length}`);\n\nconst processedIds = new Set(processedDocs\n  .filter(item => item.json && item.json.drive_file_id)\n  .map(item => item.json.drive_file_id));\n\nconst newFiles = driveFiles.filter(item => !processedIds.has(item.json.id));\n\nreturn newFiles;"
      },
