      "id": "40d29476-600a-409b-8ec8-11e57a4298bf",
      "name": "Gemini Multimodal",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        208,
        2880
      ]
    },
    {
      "parameters": {
        "jsCode": "try {\n  const geminiResponseText = $json.candidates[0].content.parts[0].text;\n  \n  let cleanJson = geminiResponseText.trim();\n  if (cleanJson.startsWith('```json')) {\n    cleanJson = cleanJson.substring(7);\n  }\n  if (cleanJson.startsWith('```')) {\n    cleanJson = cleanJson.substring(3);\n  }\n  if (cleanJson.endsWith('```')) {\n    cleanJson = cleanJson.substring(0, cleanJson.length - 3);\n  }\n  \n  const exercises = JSON.parse(cleanJson);\n  const docId = $node[\"Insert Processing Doc\"].json[\"id\"];\n  \n  const supabasePayload = exercises.map(ex => ({\n    type: ex.type,\n    language: ex.language,\n    difficulty: ex.difficulty,\n    title: ex.title,\n    content: ex.content,\n    source_document: docId,\n    active: true\n  }));\n  \n  return { json: { supabasePayload, total: supabasePayload.length, docId } };\n} catch (e) {\n  throw new Error(\"Fallo al parsear el JSON de Gemini: \" + e.message);\n}"
      },
