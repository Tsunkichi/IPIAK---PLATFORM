            "id": "7585b1c5-9f5b-4ecf-a42e-15d9475f41dc",
            "name": "Get Processed Docs",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                440,
                0
            ]
        },
        {
            "parameters": {
                "jsCode": "const driveFiles = $('List Drive Files').all();\nconst processedDocs = $input.all();\n\n// Extraer los IDs ya procesados\nconst processedIds = processedDocs.map(item => item.json.drive_file_id);\n\n// Filtrar archivos de Drive que no esten en Supabase\nconst newFiles = driveFiles.filter(item => !processedIds.includes(item.json.id));\n\nreturn newFiles;"
            },
            "id": "67fcd595-aba5-48b0-81f1-3d711f7c3574",
            "name": "Filter New Files",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                660,
                0
            ]
        },
        {
