            "id": "0d62a3fa-2395-4d7a-afc3-5c2194680c65",
            "name": "Download PDF",
            "type": "n8n-nodes-base.googleDrive",
            "typeVersion": 2,
            "position": [
                1300,
                0
            ],
            "credentials": {
                "googleDriveOAuth2Api": {
                    "id": "TU_ID_DE_CREDENCIAL_AQUI",
                    "name": "Google Drive account"
                }
