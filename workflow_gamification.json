                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ $json.supabasePayload }}",
                "options": {}
            },
            "id": "848ecead-2f88-4e89-9a25-be9fc39bb258",
